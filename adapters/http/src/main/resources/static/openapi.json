{
  "openapi": "3.0.3",
  "info": {
    "title": "礼金记账系统 API",
    "description": "## 简介\n\n礼金记账系统是一个用于管理人情往来的应用，帮助用户记录收送礼金、管理宾客关系、追踪活动账本。\n\n## 功能特性\n\n- 🔐 **用户认证** - 注册、登录、JWT令牌管理\n- 🎁 **礼物管理** - 记录收礼/送礼，支持分页筛选\n- 👥 **宾客管理** - 维护宾客信息和关系\n- 📖 **活动账本** - 按活动分类管理礼金记录\n- 📊 **统计报告** - 收支汇总和趋势分析\n- 🔔 **智能提醒** - 还礼提醒功能\n\n## 认证方式\n\n所有需要认证的接口都需要在请求头中携带 JWT 令牌：\n\n```\nAuthorization: Bearer <your_access_token>\n```\n\n## 错误码说明\n\n| 状态码 | 说明 |\n|--------|------|\n| 200 | 请求成功 |\n| 201 | 创建成功 |\n| 204 | 删除成功 |\n| 400 | 请求参数错误 |\n| 401 | 未授权/令牌无效 |\n| 404 | 资源不存在 |\n| 500 | 服务器内部错误 |",
    "version": "2.0.0",
    "contact": {
      "name": "Gift Ledger 技术支持",
      "email": "support@giftledger.com"
    },
    "license": {
      "name": "MIT",
      "url": "https://opensource.org/licenses/MIT"
    }
  },
  "servers": [
    {
      "url": "http://localhost:8081",
      "description": "本地开发服务器"
    }
  ],
  "tags": [
    {"name": "认证", "description": "用户注册、登录、令牌管理相关接口"},
    {"name": "用户管理", "description": "用户资料查询和修改"},
    {"name": "礼物管理", "description": "礼金记录的增删改查"},
    {"name": "宾客管理", "description": "宾客信息的增删改查"},
    {"name": "活动账本", "description": "活动账本的增删改查"},
    {"name": "报告统计", "description": "数据统计和报告"},
    {"name": "提醒功能", "description": "还礼提醒相关"},
    {"name": "数据导出", "description": "数据导出功能"},
    {"name": "系统", "description": "系统状态检查"}
  ],
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "description": "使用登录接口获取的 accessToken 进行身份验证"
      }
    },
    "schemas": {
      "ErrorResponse": {
        "type": "object",
        "description": "错误响应格式",
        "properties": {
          "error": {"type": "string", "description": "错误信息", "example": "验证失败"},
          "type": {"type": "string", "description": "错误类型", "default": "Error"},
          "details": {"type": "object", "description": "详细错误信息", "additionalProperties": {"type": "string"}}
        }
      }
,
      "GiftResponse": {
        "type": "object",
        "description": "礼物记录响应",
        "properties": {
          "id": {"type": "string", "format": "uuid", "description": "礼物记录唯一标识"},
          "guestId": {"type": "string", "format": "uuid", "description": "关联的宾客ID"},
          "isReceived": {"type": "boolean", "description": "是否为收礼（true=收礼，false=送礼）"},
          "amount": {"type": "number", "description": "金额（元）", "example": 500},
          "eventType": {"type": "string", "description": "活动类型", "example": "婚礼"},
          "eventBookId": {"type": "string", "format": "uuid", "nullable": true, "description": "关联的活动账本ID（可选）"},
          "occurredAt": {"type": "string", "format": "date", "description": "发生日期", "example": "2024-01-15"},
          "note": {"type": "string", "nullable": true, "description": "备注信息"},
          "relatedGiftId": {"type": "string", "format": "uuid", "nullable": true, "description": "关联的礼物ID（用于标记已还礼）"},
          "isReturned": {"type": "boolean", "description": "是否已还礼"},
          "createdAt": {"type": "string", "format": "date-time", "description": "创建时间"},
          "updatedAt": {"type": "string", "format": "date-time", "description": "更新时间"}
        }
      },
      "GuestResponse": {
        "type": "object",
        "description": "宾客信息响应",
        "properties": {
          "id": {"type": "string", "format": "uuid", "description": "宾客唯一标识"},
          "name": {"type": "string", "description": "宾客姓名", "example": "张三"},
          "relationship": {"type": "string", "description": "与用户的关系", "example": "同事"},
          "phone": {"type": "string", "nullable": true, "description": "联系电话", "example": "13800138000"},
          "note": {"type": "string", "nullable": true, "description": "备注信息"},
          "createdAt": {"type": "string", "format": "date-time", "description": "创建时间"},
          "updatedAt": {"type": "string", "format": "date-time", "description": "更新时间"}
        }
      },
      "EventBookResponse": {
        "type": "object",
        "description": "活动账本响应",
        "properties": {
          "id": {"type": "string", "format": "uuid", "description": "活动账本唯一标识"},
          "name": {"type": "string", "description": "活动名称", "example": "张三婚礼"},
          "type": {"type": "string", "description": "活动类型", "example": "婚礼"},
          "eventDate": {"type": "string", "format": "date", "description": "活动日期", "example": "2024-05-01"},
          "lunarDate": {"type": "string", "nullable": true, "description": "农历日期", "example": "三月廿三"},
          "note": {"type": "string", "nullable": true, "description": "备注信息"},
          "createdAt": {"type": "string", "format": "date-time", "description": "创建时间"},
          "updatedAt": {"type": "string", "format": "date-time", "description": "更新时间"}
        }
      },
      "UserProfileResponse": {
        "type": "object",
        "description": "用户资料响应",
        "properties": {
          "id": {"type": "string", "format": "uuid", "description": "用户唯一标识"},
          "username": {"type": "string", "description": "用户名", "example": "zhangsan"},
          "email": {"type": "string", "format": "email", "description": "邮箱地址", "example": "zhangsan@example.com"},
          "fullName": {"type": "string", "nullable": true, "description": "真实姓名", "example": "张三"},
          "createdAt": {"type": "string", "format": "date-time", "description": "注册时间"}
        }
      }
    }
  }
,
  "paths": {
    "/auth/register": {
      "post": {
        "tags": ["认证"],
        "summary": "用户注册",
        "description": "创建新用户账号。邮箱必须唯一，密码至少8位。",
        "operationId": "register",
        "requestBody": {
          "required": true,
          "description": "注册信息",
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["email", "password", "username"],
                "properties": {
                  "email": {"type": "string", "format": "email", "description": "邮箱地址（用于登录）", "example": "user@example.com"},
                  "password": {"type": "string", "minLength": 8, "description": "密码（至少8位）", "example": "password123"},
                  "username": {"type": "string", "description": "用户名", "example": "zhangsan"},
                  "fullName": {"type": "string", "description": "真实姓名（可选）", "example": "张三"}
                }
              }
            }
          }
        },
        "responses": {
          "200": {"description": "注册成功，返回用户信息"},
          "400": {"description": "验证失败（邮箱已存在/格式错误/密码太短）", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ErrorResponse"}}}}
        }
      }
    },
    "/auth/login": {
      "post": {
        "tags": ["认证"],
        "summary": "用户登录",
        "description": "使用邮箱和密码登录，获取访问令牌和刷新令牌。",
        "operationId": "login",
        "requestBody": {
          "required": true,
          "description": "登录凭证",
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["email", "password"],
                "properties": {
                  "email": {"type": "string", "format": "email", "description": "注册时使用的邮箱", "example": "user@example.com"},
                  "password": {"type": "string", "description": "账号密码", "example": "password123"}
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "登录成功",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "accessToken": {"type": "string", "description": "访问令牌（用于API调用，有效期1小时）"},
                    "refreshToken": {"type": "string", "description": "刷新令牌（用于获取新的访问令牌，有效期7天）"},
                    "expiresIn": {"type": "integer", "description": "访问令牌有效期（秒）", "example": 3600}
                  }
                }
              }
            }
          },
          "401": {"description": "邮箱或密码错误"}
        }
      }
    }
,
    "/auth/refresh": {
      "post": {
        "tags": ["认证"],
        "summary": "刷新访问令牌",
        "description": "使用刷新令牌获取新的访问令牌。当访问令牌过期时调用此接口。",
        "operationId": "refreshToken",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["refreshToken"],
                "properties": {
                  "refreshToken": {"type": "string", "description": "登录时获取的刷新令牌"}
                }
              }
            }
          }
        },
        "responses": {
          "200": {"description": "刷新成功，返回新的令牌对"},
          "401": {"description": "刷新令牌无效或已过期"}
        }
      }
    },
    "/auth/logout": {
      "post": {
        "tags": ["认证"],
        "summary": "用户登出",
        "description": "撤销刷新令牌，使其失效。建议在用户主动登出时调用。",
        "operationId": "logout",
        "security": [{"bearerAuth": []}],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["refreshToken"],
                "properties": {
                  "refreshToken": {"type": "string", "description": "要撤销的刷新令牌"}
                }
              }
            }
          }
        },
        "responses": {
          "200": {"description": "登出成功"},
          "401": {"description": "未授权"}
        }
      }
    },
    "/auth/change-password": {
      "post": {
        "tags": ["认证"],
        "summary": "修改密码",
        "description": "修改当前用户的登录密码。需要提供当前密码进行验证。",
        "operationId": "changePassword",
        "security": [{"bearerAuth": []}],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["currentPassword", "newPassword"],
                "properties": {
                  "currentPassword": {"type": "string", "description": "当前密码"},
                  "newPassword": {"type": "string", "minLength": 8, "description": "新密码（至少8位）"}
                }
              }
            }
          }
        },
        "responses": {
          "200": {"description": "密码修改成功"},
          "400": {"description": "当前密码错误或新密码不符合要求"},
          "401": {"description": "未授权"}
        }
      }
    }
,
    "/users/me": {
      "get": {
        "tags": ["用户管理"],
        "summary": "获取当前用户资料",
        "description": "获取当前登录用户的详细资料信息。",
        "operationId": "getCurrentUser",
        "security": [{"bearerAuth": []}],
        "responses": {
          "200": {
            "description": "获取成功",
            "content": {"application/json": {"schema": {"$ref": "#/components/schemas/UserProfileResponse"}}}
          },
          "401": {"description": "未授权"}
        }
      },
      "put": {
        "tags": ["用户管理"],
        "summary": "更新用户资料",
        "description": "更新当前用户的资料信息。只需提供要修改的字段。",
        "operationId": "updateProfile",
        "security": [{"bearerAuth": []}],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "username": {"type": "string", "description": "新用户名"},
                  "email": {"type": "string", "format": "email", "description": "新邮箱地址"},
                  "fullName": {"type": "string", "description": "真实姓名"}
                }
              }
            }
          }
        },
        "responses": {
          "200": {"description": "更新成功", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/UserProfileResponse"}}}},
          "400": {"description": "验证失败（邮箱格式错误等）"},
          "401": {"description": "未授权"}
        }
      }
    }
,
    "/gifts": {
      "get": {
        "tags": ["礼物管理"],
        "summary": "获取礼物列表",
        "description": "分页获取当前用户的礼物记录列表，支持按宾客、活动账本、收送类型筛选。",
        "operationId": "listGifts",
        "security": [{"bearerAuth": []}],
        "parameters": [
          {"name": "page", "in": "query", "description": "页码（从1开始）", "schema": {"type": "integer", "default": 1, "minimum": 1}},
          {"name": "pageSize", "in": "query", "description": "每页数量", "schema": {"type": "integer", "default": 20, "minimum": 1, "maximum": 100}},
          {"name": "guestId", "in": "query", "description": "按宾客ID筛选", "schema": {"type": "string", "format": "uuid"}},
          {"name": "eventBookId", "in": "query", "description": "按活动账本ID筛选", "schema": {"type": "string", "format": "uuid"}},
          {"name": "isReceived", "in": "query", "description": "按收送类型筛选（true=收礼，false=送礼）", "schema": {"type": "boolean"}}
        ],
        "responses": {
          "200": {
            "description": "获取成功",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "gifts": {"type": "array", "items": {"$ref": "#/components/schemas/GiftResponse"}, "description": "礼物记录列表"},
                    "total": {"type": "integer", "description": "总记录数"},
                    "page": {"type": "integer", "description": "当前页码"},
                    "pageSize": {"type": "integer", "description": "每页数量"}
                  }
                }
              }
            }
          },
          "401": {"description": "未授权"}
        }
      },
      "post": {
        "tags": ["礼物管理"],
        "summary": "创建礼物记录",
        "description": "创建一条新的礼金记录。宾客必须存在，活动账本可选。",
        "operationId": "createGift",
        "security": [{"bearerAuth": []}],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["guestId", "isReceived", "amount", "eventType", "occurredAt"],
                "properties": {
                  "guestId": {"type": "string", "format": "uuid", "description": "宾客ID（必须是已存在的宾客）"},
                  "isReceived": {"type": "boolean", "description": "是否为收礼（true=收礼，false=送礼）"},
                  "amount": {"type": "number", "minimum": 0.01, "description": "金额（必须大于0）", "example": 500},
                  "eventType": {"type": "string", "description": "活动类型", "example": "婚礼"},
                  "eventBookId": {"type": "string", "format": "uuid", "description": "活动账本ID（可选）"},
                  "occurredAt": {"type": "string", "format": "date", "description": "发生日期", "example": "2024-01-15"},
                  "note": {"type": "string", "description": "备注信息"}
                }
              }
            }
          }
        },
        "responses": {
          "201": {"description": "创建成功", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/GiftResponse"}}}},
          "400": {"description": "验证失败（金额无效/宾客不存在等）"},
          "401": {"description": "未授权"}
        }
      }
    }
,
    "/gifts/{id}": {
      "get": {
        "tags": ["礼物管理"],
        "summary": "获取礼物详情",
        "description": "根据ID获取单条礼物记录的详细信息。",
        "operationId": "getGift",
        "security": [{"bearerAuth": []}],
        "parameters": [
          {"name": "id", "in": "path", "required": true, "description": "礼物记录ID", "schema": {"type": "string", "format": "uuid"}}
        ],
        "responses": {
          "200": {"description": "获取成功", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/GiftResponse"}}}},
          "401": {"description": "未授权"},
          "404": {"description": "礼物记录不存在"}
        }
      },
      "put": {
        "tags": ["礼物管理"],
        "summary": "更新礼物记录",
        "description": "更新指定的礼物记录。只需提供要修改的字段。",
        "operationId": "updateGift",
        "security": [{"bearerAuth": []}],
        "parameters": [
          {"name": "id", "in": "path", "required": true, "description": "礼物记录ID", "schema": {"type": "string", "format": "uuid"}}
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "guestId": {"type": "string", "format": "uuid", "description": "新的宾客ID"},
                  "isReceived": {"type": "boolean", "description": "是否为收礼"},
                  "amount": {"type": "number", "minimum": 0.01, "description": "新金额"},
                  "eventType": {"type": "string", "description": "新活动类型"},
                  "eventBookId": {"type": "string", "format": "uuid", "description": "新活动账本ID"},
                  "occurredAt": {"type": "string", "format": "date", "description": "新发生日期"},
                  "note": {"type": "string", "description": "新备注"}
                }
              }
            }
          }
        },
        "responses": {
          "200": {"description": "更新成功", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/GiftResponse"}}}},
          "400": {"description": "验证失败"},
          "401": {"description": "未授权"},
          "404": {"description": "礼物记录不存在"}
        }
      },
      "delete": {
        "tags": ["礼物管理"],
        "summary": "删除礼物记录",
        "description": "删除指定的礼物记录。此操作不可恢复。",
        "operationId": "deleteGift",
        "security": [{"bearerAuth": []}],
        "parameters": [
          {"name": "id", "in": "path", "required": true, "description": "礼物记录ID", "schema": {"type": "string", "format": "uuid"}}
        ],
        "responses": {
          "204": {"description": "删除成功"},
          "401": {"description": "未授权"},
          "404": {"description": "礼物记录不存在"}
        }
      }
    }
,
    "/guests": {
      "get": {
        "tags": ["宾客管理"],
        "summary": "获取宾客列表",
        "description": "分页获取当前用户的宾客列表，支持按姓名搜索。",
        "operationId": "listGuests",
        "security": [{"bearerAuth": []}],
        "parameters": [
          {"name": "page", "in": "query", "description": "页码（从1开始）", "schema": {"type": "integer", "default": 1}},
          {"name": "pageSize", "in": "query", "description": "每页数量", "schema": {"type": "integer", "default": 20}},
          {"name": "search", "in": "query", "description": "按姓名模糊搜索", "schema": {"type": "string"}, "example": "张"}
        ],
        "responses": {
          "200": {
            "description": "获取成功",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "guests": {"type": "array", "items": {"$ref": "#/components/schemas/GuestResponse"}, "description": "宾客列表"},
                    "total": {"type": "integer", "description": "总记录数"},
                    "page": {"type": "integer", "description": "当前页码"},
                    "pageSize": {"type": "integer", "description": "每页数量"}
                  }
                }
              }
            }
          },
          "401": {"description": "未授权"}
        }
      },
      "post": {
        "tags": ["宾客管理"],
        "summary": "创建宾客",
        "description": "添加一个新的宾客记录。",
        "operationId": "createGuest",
        "security": [{"bearerAuth": []}],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["name", "relationship"],
                "properties": {
                  "name": {"type": "string", "description": "宾客姓名", "example": "张三"},
                  "relationship": {"type": "string", "description": "与用户的关系", "example": "同事"},
                  "phone": {"type": "string", "description": "联系电话", "example": "13800138000"},
                  "note": {"type": "string", "description": "备注信息"}
                }
              }
            }
          }
        },
        "responses": {
          "201": {"description": "创建成功", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/GuestResponse"}}}},
          "400": {"description": "验证失败（姓名或关系为空）"},
          "401": {"description": "未授权"}
        }
      }
    }
,
    "/guests/{id}": {
      "get": {
        "tags": ["宾客管理"],
        "summary": "获取宾客详情",
        "description": "根据ID获取单个宾客的详细信息。",
        "operationId": "getGuest",
