    "/reports/summary": {
      "get": {
        "tags": ["报告统计"],
        "summary": "获取统计报告",
        "description": "获取指定时间范围内的收支统计汇总，包括总收礼金额、总送礼金额、净收支等。",
        "operationId": "getSummaryReport",
        "security": [{"bearerAuth": []}],
        "parameters": [
          {"name": "from", "in": "query", "description": "开始日期", "schema": {"type": "string", "format": "date"}, "example": "2024-01-01"},
          {"name": "to", "in": "query", "description": "结束日期", "schema": {"type": "string", "format": "date"}, "example": "2024-12-31"}
        ],
        "responses": {
          "200": {
            "description": "获取成功",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "totalReceived": {"type": "number", "description": "总收礼金额"},
                    "totalSent": {"type": "number", "description": "总送礼金额"},
                    "netAmount": {"type": "number", "description": "净收支（收礼-送礼）"},
                    "giftCount": {"type": "integer", "description": "礼物记录总数"},
                    "guestCount": {"type": "integer", "description": "涉及宾客数"}
                  }
                }
              }
            }
          },
          "401": {"description": "未授权"}
        }
      }
    },
